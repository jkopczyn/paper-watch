# Copy to .env and fill in. Never commit .env.

# Gmail SMTP app password (https://myaccount.google.com/apppasswords)
SMTP_APP_PASSWORD=

# Anthropic API key for enrichment (TL;DR, tags, relevance gate)
ANTHROPIC_API_KEY=

# Slack user tokens (xoxp-…), one per workspace. The env var names must match
# `token_env` in config.yaml's slack.workspaces. Scopes: channels:history,
# groups:history, channels:read. Leave blank to skip that workspace.
SLACK_TOKEN_MATS=
SLACK_TOKEN_FAR=
SLACK_TOKEN_ALIGNMENT=

# OpenReview account (your normal website login). Optional: set both to read
# login-gated submissions' abstracts; leave blank to resolve only public notes.
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
